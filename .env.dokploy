# =============================================================================
# CLOUDCLI UI - DOKPLOY ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy file ini ke Dokploy dan isi nilai yang diperlukan
# File ini berisi SEMUA environment variables yang didukung aplikasi
#
# PENTING: Minimal salah satu dari CLAUDE_SETTINGS_JSON atau ANTHROPIC_AUTH_TOKEN
# harus diisi agar Claude CLI berfungsi
#
# INCLUDED TOOLS:
# - Claude CLI (installed in container)
# - Task-Master-AI (installed in container)
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
SERVER_PORT=3001

# Frontend dev server port (tidak digunakan di production, untuk reference saja)
VITE_PORT=5173

# Host/IP to bind servers to
# Gunakan 0.0.0.0 untuk semua interfaces
HOST=0.0.0.0

# Node environment
NODE_ENV=production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# Default di container: /app/data/auth.db
DATABASE_PATH=/app/data/auth.db

# =============================================================================
# CLAUDE / AI CONFIGURATION
# =============================================================================

# Context window size (maximum tokens per session)
CONTEXT_WINDOW=160000
VITE_CONTEXT_WINDOW=160000

# Custom Claude CLI path (jika tidak di PATH default)
# CLAUDE_CLI_PATH=claude

# Tool approval timeout in milliseconds
# CLAUDE_TOOL_APPROVAL_TIMEOUT_MS=55000

# =============================================================================
# CLAUDE AUTHENTICATION (Required - Pilih salah satu)
# =============================================================================

# --- OPSI 1: Full Settings JSON (Recommended) ---
# Encode settings.json sebagai base64:
#   Linux/Mac: cat ~/.claude/settings.json | base64 -w 0
#   Atau gunakan JSON langsung (tanpa base64)
# CLAUDE_SETTINGS_JSON=

# --- OPSI 2: Anthropic API Key (Minimal) ---
# Untuk Anthropic API standard
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_AUTH_TOKEN=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- OPSI 3: MCP OAuth Credentials ---
# Jika menggunakan MCP dengan OAuth
# Encode credentials.json sebagai base64:
#   cat ~/.claude/.credentials.json | base64 -w 0
# CLAUDE_CREDENTIALS_JSON=

# --- OPSI 4: Custom CLAUDE.md ---
# Untuk custom instructions
# CLAUDE_MD=

# =============================================================================
# OPENAI / GEMINI CONFIGURATION (Optional)
# =============================================================================

# OpenAI API Key (jika menggunakan OpenAI/Codex)
# OPENAI_API_KEY=sk-xxxxx

# Gemini CLI path
# GEMINI_PATH=gemini

# Gemini API Key
# GEMINI_API_KEY=xxxxx

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret untuk authentication
# Jika tidak diset, akan generate random secret
# PENTING: Set ini untuk consistent auth across restarts
# JWT_SECRET=your-secure-random-string-here

# API Key untuk protected endpoints
# Jika diset, semua API calls harus include header: X-API-Key
# API_KEY=your-api-key-here

# =============================================================================
# PLATFORM CONFIGURATION (Optional)
# =============================================================================

# Set ke "true" jika running sebagai platform (multi-tenant)
# VITE_IS_PLATFORM=false

# Workspaces root directory
# Default: home directory user
# WORKSPACES_ROOT=/home/appuser

# =============================================================================
# CARA MENDAPATKAN CLAUDE SETTINGS:
# =============================================================================
#
# 1. Di komputer yang sudah login Claude CLI:
#    cat ~/.claude/settings.json
#
# 2. Encode sebagai base64 untuk Dokploy:
#    cat ~/.claude/settings.json | base64 -w 0
#
# 3. Copy hasilnya ke CLAUDE_SETTINGS_JSON di Dokploy
#
# =============================================================================
# CONTOH MINIMAL CONFIGURATION:
# =============================================================================
#
# SERVER_PORT=3001
# HOST=0.0.0.0
# NODE_ENV=production
# DATABASE_PATH=/app/data/auth.db
# CONTEXT_WINDOW=160000
# VITE_CONTEXT_WINDOW=160000
# ANTHROPIC_AUTH_TOKEN=your-token-here
#
# =============================================================================
