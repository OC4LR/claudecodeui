# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy file ini ke Dokploy dan sesuaikan nilai jika diperlukan
#
# PENTING:
# - Claude CLI harus sudah terinstall di host server
# - Claude CLI harus sudah di-authenticate (claude login)
# - Volume mounts harus dikonfigurasi di Dokploy untuk akses Claude CLI
# =============================================================================

# Server Configuration
SERVER_PORT=3001
HOST=0.0.0.0

# Database Configuration
# Database akan disimpan di Docker volume untuk persistence
DATABASE_PATH=/app/data/auth.db

# Context Window Configuration
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000

# Claude CLI Path
# Default: claude (akan dicari di PATH)
# Uncomment dan sesuaikan jika Claude CLI di path berbeda
# CLAUDE_CLI_PATH=claude

# =============================================================================
# VOLUME MOUNTS YANG DIPERLUKAN DI DOKPLOY:
# =============================================================================
# 1. Claude CLI binary:
#    Host: /usr/local/bin/claude (atau path Claude CLI di server Anda)
#    Container: /usr/local/bin/claude
#
# 2. Claude config directory:
#    Host: ~/.claude (atau /root/.claude)
#    Container: /root/.claude
# =============================================================================
